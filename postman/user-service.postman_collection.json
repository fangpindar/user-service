{
  "info": {
    "name": "User Service API",
    "description": "Member registration, 2FA login, last-login query.\n\nTypical flow:\n1. Register\n2. Open activation link from email → click [Activate] button\n3. Login (Phase 1) → OTP sent to email\n4. Verify OTP (Phase 2) → access + refresh tokens\n5. GET /me/last-login\n6. (Optional) Refresh, Logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost", "type": "string" },
    { "key": "email", "value": "test@example.com", "type": "string" },
    { "key": "password", "value": "Test1234", "type": "string" },
    { "key": "activationToken", "value": "", "type": "string" },
    { "key": "challengeId", "value": "", "type": "string" },
    { "key": "otpCode", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      }
    },
    {
      "name": "2. Resend activation",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/resend-activation",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        }
      }
    },
    {
      "name": "3a. GET /activate (confirmation page)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/auth/activate?token={{activationToken}}"
      }
    },
    {
      "name": "3b. POST /activate (perform activation)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/activate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{activationToken}}\"\n}"
        }
      }
    },
    {
      "name": "4. Login (Phase 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.challengeId) pm.collectionVariables.set('challengeId', data.challengeId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      }
    },
    {
      "name": "5. Verify OTP (Phase 2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/verify-otp",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"challengeId\": \"{{challengeId}}\",\n  \"code\": \"{{otpCode}}\"\n}"
        }
      }
    },
    {
      "name": "6. GET /me/last-login",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/users/me/last-login"
      }
    },
    {
      "name": "7. Refresh tokens",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "8. Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/auth/logout"
      }
    }
  ]
}
