# =====================================================
# Database
# =====================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=userdb
DB_USER=postgres
DB_PASSWORD=changeme

# =====================================================
# Redis
# =====================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =====================================================
# JWT (production: openssl rand -base64 48)
# Both must be at least 32 bytes (256 bits) for HS256
# =====================================================
JWT_ACCESS_SECRET=replace-me-with-32-plus-bytes-random-string-please-do-not-use-in-prod
JWT_REFRESH_SECRET=replace-me-different-32-plus-bytes-random-string-please-do-not-use-in-prod

# =====================================================
# SendGrid
# Get from: https://app.sendgrid.com/settings/api_keys
# =====================================================
SENDGRID_API_KEY=SG.replace-with-your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com

# =====================================================
# App
# APP_BASE_URL is used in activation email links.
# - Local:  http://localhost
# - EC2:    http://ec2-x-x-x-x.ap-northeast-1.compute.amazonaws.com
# =====================================================
APP_BASE_URL=http://localhost
SPRING_PROFILES_ACTIVE=dev
